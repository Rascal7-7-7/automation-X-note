{
  "name": "note 投稿 → X告知（火曜 10:00）",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 10 * * 2" }]
        }
      },
      "id": "n8n-note-post-trigger",
      "name": "火曜 10:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3001/api/note/post",
        "options": { "timeout": 120000 }
      },
      "id": "n8n-note-post-call",
      "name": "note 下書き保存",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": { "amount": 15, "unit": "minutes" },
      "id": "n8n-note-post-wait",
      "name": "15分待機（手動公開の猶予）",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [680, 300],
      "webhookId": "note-post-wait"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3001/api/x/note-promo",
        "options": { "timeout": 30000 }
      },
      "id": "n8n-note-promo-call",
      "name": "X 告知ツイート",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300]
    }
  ],
  "connections": {
    "火曜 10:00":              { "main": [[{ "node": "note 下書き保存",          "type": "main", "index": 0 }]] },
    "note 下書き保存":         { "main": [[{ "node": "15分待機（手動公開の猶予）", "type": "main", "index": 0 }]] },
    "15分待機（手動公開の猶予）": { "main": [[{ "node": "X 告知ツイート",          "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "versionId": "1"
}
