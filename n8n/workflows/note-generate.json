{
  "name": "note 記事生成（月曜 10:00 → 11:00）",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 10 * * 1" }]
        }
      },
      "id": "n8n-note-gen-trigger",
      "name": "月曜 10:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3001/api/note/generate",
        "options": { "timeout": 180000 }
      },
      "id": "n8n-note-gen-call",
      "name": "記事生成",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": { "amount": 60, "unit": "minutes" },
      "id": "n8n-note-gen-wait",
      "name": "60分待機",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [680, 300],
      "webhookId": "note-gen-wait"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3001/api/note/image",
        "options": { "timeout": 120000 }
      },
      "id": "n8n-note-image-call",
      "name": "ヘッダー画像生成",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300]
    }
  ],
  "connections": {
    "月曜 10:00":   { "main": [[{ "node": "記事生成",         "type": "main", "index": 0 }]] },
    "記事生成":     { "main": [[{ "node": "60分待機",         "type": "main", "index": 0 }]] },
    "60分待機":     { "main": [[{ "node": "ヘッダー画像生成", "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
  "versionId": "1"
}
