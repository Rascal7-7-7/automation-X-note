# ────────────────────────────────────────────────────────────────────
# X（Twitter）ブラウザ自動化（必須）
# ────────────────────────────────────────────────────────────────────
X_EMAIL=your-x-email@example.com
X_PASSWORD=your-x-password

# ────────────────────────────────────────────────────────────────────
# X API（任意 — 未設定時はブラウザ経由で投稿・収集）
# フォロワーが増えてきたらAPIに切り替えることで安定性が向上する
# ────────────────────────────────────────────────────────────────────
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
# X_BEARER_TOKEN=

# ────────────────────────────────────────────────────────────────────
# AI（必須）
# ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ────────────────────────────────────────────────────────────────────
# OpenAI（note 画像生成に使用）
# ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ────────────────────────────────────────────────────────────────────
# note（ブラウザ自動化）
# ────────────────────────────────────────────────────────────────────
NOTE_EMAIL=your-note-email@example.com
NOTE_PASSWORD=your-note-password

# ────────────────────────────────────────────────────────────────────
# Instagram（Graph API）
# ────────────────────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN_1=IGAANRc...        # @account1 トークン
INSTAGRAM_BUSINESS_ACCOUNT_ID_1=278...
INSTAGRAM_ACCESS_TOKEN_2=EAA3iw...        # @account2 トークン
INSTAGRAM_BUSINESS_ACCOUNT_ID_2=178...

# ────────────────────────────────────────────────────────────────────
# Instagram Reels 動画生成（優先順位: HeyGen > D-ID > ffmpeg自動）
# ────────────────────────────────────────────────────────────────────
# --- 優先1: HeyGen（$29/月〜、高品質アバター） ---
# HEYGEN_API_KEY=
# HEYGEN_AVATAR_ID=           # 省略可: アカウント内の最初のアバターを使用
# HEYGEN_VOICE_ID_JA=         # 省略可: 女性日本語ボイスを自動選択

# --- 優先2: D-ID（$5.99/月〜、顔写真+TTSアバター） ---
# DID_API_KEY=                # "your-email@example.com:api_key_here" 形式
# DID_AVATAR_IMAGE_URL=       # 省略可: デフォルト女性アバターを使用
# DID_VOICE_ID=               # 省略可: ja-JP-NanamiNeural

# --- フォールバック: ffmpeg（無料、テキスト+画像スライドショー） ---
# APIキー未設定時に自動的にこちらを使用

# ────────────────────────────────────────────────────────────────────
# YouTube（Data API v3）
# ────────────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=       # node youtube/get-refresh-token.js で取得
YOUTUBE_CHANNEL_ID=          # YouTube Studio から確認

# ────────────────────────────────────────────────────────────────────
# スケジューラ
#   dev  → DEV_TASK で指定したタスクを1回だけ実行して終了
#   prod → 全タスクを cron で常時稼働
# ────────────────────────────────────────────────────────────────────
MODE=dev
# DEV_TASK=x:enqueue
